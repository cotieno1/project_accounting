# Copy to .env for local overrides (never commit .env)
# On Railway, set these in Project -> Variables instead.

SECRET_KEY=change-me-to-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=your-app.up.railway.app
CSRF_TRUSTED_ORIGINS=https://your-app.up.railway.app

# Railway PostgreSQL plugin sets this automatically:
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# Email (required on Railway for user onboarding)
SITE_BASE_URL=https://your-app.up.railway.app

# Option A — Resend (easiest on Railway: one API key, no SMTP port)
# Sign up at https://resend.com, verify your domain, create an API key.
RESEND_API_KEY=
DEFAULT_FROM_EMAIL=Project Accounting <noreply@yourdomain.com>

# Option B — SMTP (Gmail, Outlook, etc.)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
# If using SMTP only, leave RESEND_API_KEY empty and set both EMAIL_HOST_USER and EMAIL_HOST_PASSWORD.
# Comma-separated; also falls back to User Admin accounts and superusers
SYSTEM_ADMIN_EMAIL=admin@yourdomain.com